{{!
    @template tiny_phonetic/modal

    Modal to compose and insert IPA phonetic symbols via Tiny editor.

    Classes required for JS:
    * tiny_phonetic_text
    * tiny_phonetic_preview_char

    Data attributes required for JS:
    * data-action="save"

    Context variables required for this template:
    * elementid    - unique editor ID
    * libraries    - array of library group objects (see modal_library.mustache)
    * currentvalue - pre-filled textarea content (usually empty string)

    Example context (json):
    {
        "elementid": "exampleId",
        "libraries": [],
        "currentvalue": ""
    }
}}
{{< core/modal }}

    {{$classes}}modal-lg tiny_phonetic_modal{{/classes}}

    {{$title}}
        {{#str}} pluginname, tiny_phonetic {{/str}}
    {{/title}}

    {{$body}}
        <form class="mform" id="{{uniqid}}">
            {{> tiny_phonetic/modal_library }}
            <label for="{{elementid}}_tiny_phonetic_text">{{#str}} preview, tiny_phonetic {{/str}}</label>
            <textarea class="tiny_phonetic_text w-100"
                      id="{{elementid}}_tiny_phonetic_text"
                      rows="4">{{currentvalue}}</textarea>
            <div class="tiny_phonetic_preview_char border rounded text-center p-2 mt-1"
                 aria-live="polite"
                 style="font-size: 2em; min-height: 1.5em;"></div>
            <p class="small text-muted mt-1">{{#str}} cursorinfo, tiny_phonetic {{/str}}</p>
        </form>
    {{/body}}

    {{$footer}}
        <button type="button" class="btn btn-primary" data-action="save">
            {{#str}} savephonetic, tiny_phonetic {{/str}}
        </button>
    {{/footer}}

{{/ core/modal }}
