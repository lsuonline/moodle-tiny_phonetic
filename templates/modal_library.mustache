{{!
    @template tiny_phonetic/modal_library

    Phonetic symbol library template — Bootstrap nav-tabs + tab-pane per group.

    Classes required for JS:
    * tiny_phonetic_btn

    Context variables required for this template:
    * elementid   - unique editor ID
    * libraries   - array of {key, groupname, elements, active, combining}

    Example context (json):
    {
        "elementid": "exampleId",
        "libraries": [
            {
                "key": "group1",
                "groupname": "Pulmonic Consonants",
                "elements": ["&#112;", "&#98;"],
                "active": true,
                "combining": false
            }
        ]
    }
}}
<div class="tiny_phonetic_library">
    <ul class="root nav nav-tabs mb-1" role="tablist">
        {{#libraries}}
        <li class="nav-item">
            <a class="nav-link{{#active}} active{{/active}}"{{!
               }}{{#active}} aria-selected="true"{{/active}}{{!
               }}{{^active}} aria-selected="false" tabindex="-1"{{/active}}{{!
               }} href="#{{elementid}}_tiny_phonetic_group_{{key}}"{{!
               }} data-target="#{{elementid}}_tiny_phonetic_group_{{key}}"
               role="tab" data-toggle="tab"
            >
                {{groupname}}
            </a>
        </li>
        {{/libraries}}
    </ul>
    <div class="tab-content mb-1 tiny_phonetic_groups">
        {{#libraries}}
        <div class="tab-pane{{#active}} active{{/active}}"
             id="{{elementid}}_tiny_phonetic_group_{{key}}">
            <div role="toolbar">
                {{#elements}}
                <button class="btn btn-secondary tiny_phonetic_btn"
                        data-symbol="{{.}}" aria-label="{{.}}" title="{{.}}">{{{.}}}</button>
                {{/elements}}
            </div>
            {{#combining}}
            <div class="mt-2">
                <label for="{{elementid}}_tiny_phonetic_base">
                    {{#str}} base_symbol, tiny_phonetic {{/str}}
                </label>
                <input class="tiny_phonetic_base_symbol form-control-sm d-inline-block"
                       type="text"
                       id="{{elementid}}_tiny_phonetic_base"
                       maxlength="1"
                       size="2" />
            </div>
            {{/combining}}
        </div>
        {{/libraries}}
    </div>
</div>
